### Init
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_GRUB_TIMEOUT="3"

# 固件压缩:
# 编译常规以及UEFI、EXT4固件:
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_IMAGES_PAD=y
CONFIG_TARGET_ROOTFS_EXT4FS=n

CONFIG_KERNEL_BUILD_USER="OprX"
CONFIG_GRUB_TITLE="OprX Built By ilxp"

# 设置固件大小:900刚好可以dd刷机，944则提示空间不足
### Basic  
CONFIG_ALL_KMODS=y
CONFIG_ALL_NONSHARED=y
CONFIG_KERNEL_BUILD_DOMAIN="buildhost"
CONFIG_KERNEL_MEMCG_V1=y
CONFIG_KERNEL_MPTCP=y
CONFIG_KERNEL_MPTCP_IPV6=y
# CONFIG_KERNEL_PREEMPT_RT is not set
CONFIG_PACKAGE_autocore-x86=y
CONFIG_PACKAGE_bind-host=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_default-settings=y
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=900
# CONFIG_KERNEL_KALLSYMS is not set

